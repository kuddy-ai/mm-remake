# Godot 4+
.import/
.godot/
.export/

# Environment variables
.env

# Claude project settings (contains API tokens)
.claude/settings.local.json

# External assets (source files — keep README.md)
external-assets/*
!external-assets/README.md

# Design source files in external-assets (never commit to git)
*.psd
*.ai
*.kra
*.clip
*.tiff
*.tif
external-assets/**/*.svg
*.xcf
*.aseprite
*.afdesign

# Audio source files (never commit to git)
*.flp
*.als
*.logicx
*.band
*.cpr
*.aiff
*.aif
*.wav.original

# Archives (never commit to git)
*.zip
*.rar
*.7z

# Keys and certificates (never commit to git)
*.keystore
*.p12
*.mobileprovision

# Mono / C#
.mono/
*.csproj
*.sln
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb

# Build artifacts
bin/
obj/
build/
artifacts/

# IDE: VSCode / JetBrains / Rider
.vscode/*
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln.iml

# OS
.DS_Store
Thumbs.db